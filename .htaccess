# Block directory listing
Options -Indexes

# Force HTTPS — defense-in-depth fallback for direct HTTP connections to origin.
# Primary redirect is handled by Cloudflare "Always Use HTTPS" at the edge.
# With Cloudflare Full (Strict), origin always receives HTTPS (%{HTTPS}=on), so
# this rule never fires in production — it only catches direct-to-origin HTTP bypasses.
# Skip on localhost so local development works over HTTP without SSL.

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{HTTP_HOST} !^(localhost|127\.0\.0\.1)(:[0-9]+)?$ [NC]
    RewriteCond %{HTTPS} off
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# Default document order
DirectoryIndex index.html index.php

# Block direct access to config files
<FilesMatch "^db_config\.php$">
    Require all denied
</FilesMatch>

<FilesMatch "^db_config\.example\.php$">
    Require all denied
</FilesMatch>

# Security headers (requires mod_headers)
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
